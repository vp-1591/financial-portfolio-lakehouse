# .env.example — copy this to .env and fill in your values.
# Never commit .env (it is gitignored).

# Execution mode is set via the --mode CLI flag, not an env var:
#   python -m pipeline.run full --mode docker        # local development (MinIO)
#   python -m pipeline.run run-connector ibkr --mode staging  # demo S3
#   python -m pipeline.run query "..." --mode prod   # production S3
# See docs/configuration.md for details.

# IBKR Flex Web Service (required if IBKR_ENABLED is not disabled)
# The Flex Query must include the Account Information, Open Positions, Cash
# Report and Currency Conversion Rate sections. See
# docs/ibkr/flex-query-required-fields.md for the exact fields to tick in
# the Flex Query editor.
IBKR_FLEX_TOKEN=your_token_here
IBKR_FLEX_QUERY_ID=your_query_id_here

# Trading 212 API (required if T212_ENABLED is not disabled)
# API key permissions needed (read-only, no trading):
#   ✗ Account data · ✗ History · ✗ History - Dividends · ✗ History - Orders
#   ✗ History - Transactions · ✗ Metadata · ✗ Portfolio
# See docs/trading212/api-key-permissions.md for details.
T212_API_KEY=your_key_here
T212_API_SECRET=your_secret_here

# Encryption key for financial values (required)
# Generate one with: python -m pipeline.run keygen
ENCRYPTION_KEY=your_fernet_key_here

# Optional: disable connectors by setting to "0", "false", or "no"
# IBKR_ENABLED=true
# T212_ENABLED=true
# XTB_ENABLED=true

# Optional: IBKR Flex base URL (default shown)
# IBKR_FLEX_BASE_URL=https://ndcdyn.interactivebrokers.com/AccountManagement/FlexWebService

# --- Docker mode (local development with MinIO) ---
# Set these when running with --mode docker:
S3_BUCKET=portfolio-data
S3_ENDPOINT_URL=http://minio:9000
S3_ALLOW_HTTP=true
# AWS credentials for MinIO (use MinIO access keys)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=eu-west-1

# --- Staging mode (demo S3 bucket) ---
# Set these when running with --mode staging:
# Staging mode uses base-name secrets (e.g. IBKR_FLEX_TOKEN, not IBKR_FLEX_TOKEN_DEMO).
# ECS tasks inject them from /portfolio/demo/ SSM parameters; local runs use .env.
# S3_BUCKET=pipeline-demo
# S3_PREFIX=pipeline_demo
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# State machine ARN for `full --mode staging` (from `terraform/demo` state_machine_arn output).
# Only AWS creds with states:StartExecution are needed locally — broker secrets
# are injected into ECS containers by SSM at runtime.
# STAGING_STATE_MACHINE_ARN=arn:aws:states:eu-west-1:...

# --- Production mode (production S3 bucket) ---
# Set these when running with --mode prod:
# S3_BUCKET=your-production-bucket
# S3_PREFIX=pipeline
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=eu-west-1
# State machine ARN for `full --mode prod` (from `terraform/prod` state_machine_arn output).
# PROD_STATE_MACHINE_ARN=arn:aws:states:eu-west-1:...

# Optional: Trading 212 base URL (auto-derived from --mode)
# In staging mode, defaults to https://demo.trading212.com/api/v0
# In docker/prod mode, defaults to https://live.trading212.com/api/v0
# T212_BASE_URL=https://live.trading212.com/api/v0
