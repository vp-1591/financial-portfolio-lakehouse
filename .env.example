# .env.example — copy this to .env and fill in your values.
# Never commit .env (it is gitignored).

# IBKR Flex Web Service (required if IBKR_ENABLED is not disabled)
# The Flex Query must include the Account Information, Open Positions, Cash
# Report and Currency Conversion Rate sections. See
# docs/ibkr/flex-query-required-fields.md for the exact fields to tick in
# the Flex Query editor.
IBKR_FLEX_TOKEN=your_token_here
IBKR_FLEX_QUERY_ID=your_query_id_here

# Trading 212 API (required if T212_ENABLED is not disabled)
# API key permissions needed (read-only, no trading):
#   ✗ Account data · ✗ History · ✗ History - Dividends · ✗ History - Orders
#   ✗ History - Transactions · ✗ Metadata · ✗ Portfolio
# See docs/trading212/api-key-permissions.md for details.
T212_API_KEY=your_key_here
T212_API_SECRET=your_secret_here

# Encryption key for financial values (required)
# Generate one with: python -m pipeline.run keygen
ENCRYPTION_KEY=your_fernet_key_here

# Optional: disable connectors by setting to "0", "false", or "no"
# IBKR_ENABLED=true
# T212_ENABLED=true
# XTB_ENABLED=true

# Optional: IBKR Flex base URL (default shown)
# IBKR_FLEX_BASE_URL=https://ndcdyn.interactivebrokers.com/AccountManagement/FlexWebService

# Optional: demo mode (uses _DEMO-suffixed secrets and separate storage)
# When DEMO=true, the pipeline uses demo API credentials (with _DEMO suffix)
# and writes to a separate data directory or S3 prefix. There is NO cross-mode
# fallback — missing demo credentials are a hard error.
# DEMO=false

# Demo-specific secrets (required when DEMO=true)
# IBKR_FLEX_TOKEN_DEMO=your_demo_token_here
# IBKR_FLEX_QUERY_ID_DEMO=your_demo_query_id_here
# T212_API_KEY_DEMO=your_demo_key_here
# T212_API_SECRET_DEMO=your_demo_secret_here
# ENCRYPTION_KEY_DEMO=your_demo_fernet_key_here

# Demo S3 storage (overrides bucket/prefix when DEMO=true)
# Defaults to {S3_BUCKET}-demo and pipeline_demo prefix.
# S3_BUCKET_DEMO=pipeline-demo
# S3_PREFIX_DEMO=pipeline_demo

# Demo AWS credentials (used exclusively when DEMO=true, no fallback)
# AWS_ACCESS_KEY_ID_DEMO=...
# AWS_SECRET_ACCESS_KEY_DEMO=...

# Optional: Trading 212 base URL (auto-derived from DEMO flag)
# When DEMO=true, defaults to https://demo.trading212.com/api/v0
# When DEMO=false (or unset), defaults to https://live.trading212.com/api/v0
# T212_BASE_URL=https://live.trading212.com/api/v0

# Optional: S3 cloud storage
# STORAGE_TYPE=cloud   # cloud (AWS S3), minio (S3-compatible), or local (filesystem)
# S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=eu-west-1
# S3_ENDPOINT_URL=http://minio:9000  # for MinIO or other S3-compatible stores
# S3_ALLOW_HTTP=true                   # required for non-HTTPS endpoints